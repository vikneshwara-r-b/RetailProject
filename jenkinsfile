pipeline {
    agent any

    environment {
        LABS = credentials('labcreds')
    }

    stages {
        stage('Build') {
            steps {
               sh '/usr/bin/pipenv --rm || exit 0'
               sh '/usr/bin/pipenv install'
            }
        }

          stage('Test') {
            steps {
               echo "starting the testing"
               sh '/usr/bin/pipenv run pytest'
            }
        }

         stage('Package') {
            steps {
               sh 'zip -r retailproject.zip .'
            }
        }
        
        stage('Deploy') {
            steps {
               sh 'sshpass -p $LABS_PSW scp -o StrictHostKeyChecking=no -r . $LABS_USR@g01.itversity.com:/home/itv015506/retailproject'
            }
        }
	
    }
}
